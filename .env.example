# ChatDAW Server — Environment Variables
# Add these in Railway dashboard under Variables

# Your Anthropic API key — get it at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Secret admin key — make this something long and random, only you know it
# You'll use this to generate license keys after each Gumroad sale
ADMIN_KEY=make_this_something_random_and_secret

# Port — Railway sets this automatically, leave as is
PORT=3000
